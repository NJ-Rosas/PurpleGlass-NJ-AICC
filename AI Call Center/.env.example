# Synthetic local-development values only. Copy to .env to override defaults.
POSTGRES_DB=purpleglass
POSTGRES_USER=purpleglass
POSTGRES_PASSWORD=purpleglass_dev_only
POSTGRES_PORT=5433
MQTT_PORT=1883
VALKEY_PORT=6379

# Provider-neutral Task 4 simulator settings (synthetic values only).
CallOrchestrator__Conversation__Language=en-US
CallOrchestrator__Conversation__VoiceId=calm-a
CallOrchestrator__Conversation__MaximumTurns=6
CallOrchestrator__RecognitionTimeout=00:00:02
CallOrchestrator__AiTimeout=00:00:02
CallOrchestrator__SynthesisTimeout=00:00:02
CallOrchestrator__MockAi__FailGeneration=false
CallOrchestrator__MockSpeech__FailRecognition=false
CallOrchestrator__MockSpeech__FailSynthesis=false
